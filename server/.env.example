# Server Configuration
PORT=3000
BACKEND_URL=http://localhost:3000
APP_URL=http://localhost:5173

# Database
MONGODB_URL=mongodb://localhost:27017/Sentra

# CORS Configuration
CORS_ORIGIN=["http://localhost:5173","http://localhost:3000"]

# JWT Secret
JWT_SECRET=your-secret-key-change-this

# GitHub Integration
# GitHub OAuth App Credentials (for user authentication)
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_client_secret

# GitHub Webhook Secret (for webhook signature verification)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_key

# GitHub Personal Access Token (optional fallback for service operations)
GITHUB_TOKEN=your_github_personal_access_token

# GitHub Bot Token (optional - for posting PR comments as a bot account)
# If set, comments will be posted as the bot account instead of the user
# To use: Create a separate GitHub account (e.g., sentra-bot), generate a PAT, and set it here
GITHUB_BOT_TOKEN=your_github_bot_personal_access_token

# LLM Provider Configuration
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key

# Context Job Configuration
CONTEXT_JOB_INTERVAL_MS=0

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# ============================================
# GITHUB INTEGRATION SETUP GUIDE
# ============================================

# 1. GitHub OAuth App Setup (Required for user authentication)
#    - Go to: https://github.com/settings/developers
#    - Click "New OAuth App"
#    - Application name: Sentra
#    - Homepage URL: http://localhost:5173 (or your frontend URL)
#    - Authorization callback URL: http://localhost:3000/api/auth/github/callback
#    - Copy Client ID to GITHUB_OAUTH_CLIENT_ID
#    - Generate and copy Client Secret to GITHUB_OAUTH_CLIENT_SECRET

# 2. GitHub Webhook Secret (Required for webhook verification)
#    - Generate a random secret key (32+ characters recommended)
#    - Use: openssl rand -hex 32
#    - Or use any secure random string generator
#    - Set this value in GITHUB_WEBHOOK_SECRET

# 3. GitHub Personal Access Token (Optional - for service operations)
#    - Go to: https://github.com/settings/tokens
#    - Click "Generate new token (classic)"
#    - Select scopes: repo, workflow, admin:repo_hook
#    - Copy token to GITHUB_TOKEN
#    - Note: User tokens are preferred and used when available

# 4. Webhook URL Configuration
#    - For local development: Use ngrok or similar tunneling service
#      Example: ngrok http 3000
#      Then update BACKEND_URL with the ngrok URL
#    - For production: Use your actual backend URL
#    - Webhooks will be automatically created at: {BACKEND_URL}/api/webhooks/github

# 5. GitHub Actions Workflows
#    - Workflows are managed through the /workflows page
#    - Templates are available for common CI/CD scenarios
#    - Workflows require 'workflow' scope in OAuth or PAT

# Required Scopes for GitHub Integration:
# - repo: Full control of private repositories
# - workflow: Update GitHub Action workflows
# - admin:repo_hook: Full control of repository hooks (webhooks)
